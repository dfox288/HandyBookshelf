	"authors": [
		"D.Fox"
	],
	"contact": {
		"homepage": "https://github.com/dfox288/HandyBookshelf",
		"sources": "https://github.com/dfox288/HandyBookshelf",
		"issues": "https://github.com/dfox288/HandyBookshelf/issues"
	},
	"license": "MIT",
	"icon": "assets/handybookshelf/icon.png",
