			"dev.handy.mods.handybookshelf.HandyBookshelf"
		],
		"client": [
			"dev.handy.mods.handybookshelf.client.HandyBookshelfClient"
		],
		"modmenu": [
			"dev.handy.mods.handybookshelf.client.config.ModMenuIntegration"
		]
	},
